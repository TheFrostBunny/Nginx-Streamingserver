<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title>Videoavspilling</title>
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    <script src="/vjs/video.min.js"></script>
    <style>
        body { background: #0b0e11; color: white; font-family: sans-serif; padding: 20px; }
        .container { max-width: 700px; margin: 40px auto; background: #181c20; border-radius: 8px; padding: 20px; border: 1px solid #333; }
        h1 { margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎬 Videoavspilling</h1>
        <% if (videoUrl) { %>
            <video id="main-video" class="video-js vjs-16-9 vjs-default-skin" controls autoplay style="width:100%">
                <source src="<%= videoUrl %>" type="video/mp4" />
                Din nettleser støtter ikke video.
            </video>
            <script>
                if (typeof videojs !== 'undefined') {
                    videojs('main-video');
                }
            </script>
            <p style="margin-top:10px"><%= videoName %></p>
        <% } else { %>
            <p>Ingen video valgt.</p>
        <% } %>
        <a href="/">Tilbake til dashboard</a>
    </div>
</body>
</html>
