<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title>Live Dashboard</title>
    
    <!-- CSS - Hentes nå fra din egen server -->
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    
    <!-- JS - Hentes nå fra din egen server -->
    <script src="/vjs/video.min.js"></script>

    <style>
        body { background: #0b0e11; color: white; font-family: sans-serif; padding: 20px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px; }
        .card { background: #181c20; border-radius: 8px; padding: 10px; border: 1px solid #333; }
    </style>
</head>
<body>


    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <h1 style="margin: 0;">🔴 Aktive Strømmer</h1>
        <a href="/" style="background:#4fc3f7;color:#181c20;font-weight:bold;display:inline-flex;align-items:center;gap:10px;padding:12px 20px;border-radius:6px;text-decoration:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#181c20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M9 21V9h6v12"/></svg>
            Tilbake til dashboard
        </a>
    </div>
    <div id="stream-grid" class="grid"></div>


    <script>
        let activeStreams = [];

        async function updateStreams() {
            try {
                const res = await fetch('/api/streams');
                const streams = await res.json();
                if (JSON.stringify(streams) !== JSON.stringify(activeStreams)) {
                    const grid = document.getElementById('stream-grid');
                    grid.innerHTML = '';
                    streams.forEach(id => {
                        const div = document.createElement('div');
                        div.className = 'card';
                        div.innerHTML = `
                            <video id="v-${id}" class="video-js vjs-16-9 vjs-default-skin" controls muted autoplay></video>
                            <p>Stream: ${id}</p>
                        `;
                        grid.appendChild(div);
                        if (typeof videojs !== 'undefined') {
                            videojs(`v-${id}`).src({ 
                                type: 'application/x-mpegURL', 
                                src: `/hls/${id}.m3u8` 
                            });
                        }
                    });
                    activeStreams = streams;
                }
            } catch (e) {
                console.error("Feil ved oppdatering av streams:", e);
            }
        }

        setInterval(updateStreams, 5000);
        updateStreams();
    </script>
</body>
</html>