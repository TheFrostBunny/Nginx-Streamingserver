<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title>Last opp video</title>
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    <style>
        body { background: #0b0e11; color: white; font-family: sans-serif; padding: 40px; }
        .container { max-width: 500px; margin: 60px auto; background: #181c20; border-radius: 8px; padding: 30px; border: 1px solid #333; }
        h1 { margin-bottom: 20px; }
        label { display: block; margin-bottom: 10px; }
        input[type="file"] { margin-bottom: 20px; }
        button { background: #4fc3f7; color: #181c20; font-weight: bold; border: none; border-radius: 6px; padding: 12px 24px; font-size: 1em; cursor: pointer; }
        button:hover { background: #38b6ff; }
        .msg { margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
            <h1 style="margin: 0;">Last opp video</h1>
            <a href="/" style="background:#4fc3f7;color:#181c20;font-weight:bold;display:inline-flex;align-items:center;gap:10px;padding:12px 20px;border-radius:6px;text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#181c20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M9 21V9h6v12"/></svg>
                Tilbake til dashboard
            </a>
        </div>
        <form id="uploadForm" enctype="multipart/form-data">
            <label for="video">Velg videofil:</label>
            <input type="file" name="video" id="video" accept="video/*" required />
            <div style="font-size:0.95em;color:#aaa;margin-bottom:10px;">
                <strong>Videokrav:</strong><br>
                • Kun ekte videofiler tillatt (.mp4, .webm, .ogg, .mkv, .mov, .avi, .flv, .mpeg, .3gp, .3g2)<br>
                • Maksimal filstørrelse: 500MB<br>
                • Maksimal varighet: 30 minutter<br>
                • Maksimal oppløsning: 4K (3840x2160)<br>
                • Sikre codecs og metadata kreves<br>
                • Ikke-kompatible codecs konverteres automatisk til web-kompatibel H.264/AAC<br>
                <strong style="color:#ff6b6b;">Skript-filer (.sh, .bat, .exe, etc.) er strengt forbudt!</strong>
            </div>
            <button type="submit">Last opp</button>
        </form>
        <div id="msg" class="msg"></div>
        <a href="/videos" style="color:#4fc3f7;display:inline-block;margin-top:20px;">Tilbake til videoer</a>
    </div>
    <script>
        document.getElementById('uploadForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = e.target;
            const data = new FormData(form);
            const msg = document.getElementById('msg');
            msg.textContent = 'Laster opp og verifiserer video...';
            const res = await fetch('/upload/video', {
                method: 'POST',
                body: data
            });
            if (res.ok) {
                msg.textContent = 'Video lastet opp og verifisert!';
                form.reset();
            } else {
                const err = await res.text();
                msg.textContent = 'Feil ved opplasting: ' + err;
            }
        });
    </script>
</body>
</html>
