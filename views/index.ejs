<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title>Live Dashboard</title>
    
    <!-- CSS - Hentes nå fra din egen server -->
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    <script src="/vjs/video.min.js"></script>

    <style>
        body {
            background: #0b0e11;
            color: #f3f3f3;
            font-family: 'Segoe UI', Arial, sans-serif;
            padding: 0;
            min-height: 100vh;
        }
        header {
            background: #181c20;
            padding: 24px 8vw 16px 8vw;
            position: sticky;
            top: 0;
            z-index: 10;
            box-shadow: 0 2px 8px #0003;
        }
        h1 {
            font-size: 2.2em;
            margin-bottom: 0.7em;
            letter-spacing: 0.5px;
        }
        main {
            padding: 32px 8vw 32px 8vw;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 28px;
        }
        .card {
            background: #181c20;
            border-radius: 14px;
            padding: 18px 14px 12px 14px;
            border: 1.5px solid #2e8bff44;
            box-shadow: 0 4px 16px #0006;
            transition: transform 0.18s, border 0.18s, box-shadow 0.18s;
            cursor: pointer;
        }
        .card:hover {
            transform: translateY(-4px) scale(1.03);
            border-color: #2e8bff;
            box-shadow: 0 8px 32px #2e8bff33;
        }
        .card p {
            margin: 0.7em 0 0 0;
            color: #2e8bff;
            font-size: 1.1em;
            font-weight: 500;
            letter-spacing: 0.2px;
        }
        .video-js {
            width: 100%;
            height: 220px;
            background: #222;
            border-radius: 8px;
        }
        @media (max-width: 600px) {
            header, main { padding: 12px 2vw; }
            .grid { grid-template-columns: 1fr; gap: 16px; }
            .card { padding: 10px 4px 8px 4px; }
        }
    </style>
</head>
<body>
    <header>
        <h1>🔴 Aktive Strømmer <span id="stream-count" style="font-size:0.7em;color:#7fffa7"></span></h1>
        <div style="max-width:400px;margin:0 0 18px 0;">
            <input id="stream-search" type="text" placeholder="Søk etter stream..." style="width:100%;padding:8px 10px;border-radius:6px;border:1px solid #333;background:#232a34;color:#f3f3f3;font-size:1em;">
        </div>
    </header>
    <main>
        <div id="stream-grid" class="grid"></div>
        <div id="empty-msg" style="display:none;color:#aaa;font-size:1.2em;margin:2em 0;text-align:center;">Ingen aktive strømmer akkurat nå.</div>
        <div id="error-msg" style="display:none;color:#ff6b6b;font-size:1em;margin:1em 0;text-align:center;"></div>
    </main>

    <script>
        let activeStreams = [];

        let allStreams = [];
        async function update() {
            try {
                const res = await fetch('/api/streams');
                const streams = await res.json();
                allStreams = streams;
                renderStreams();
            } catch (e) {
                const errorMsg = document.getElementById('error-msg');
                errorMsg.textContent = 'Feil ved lasting av strømmer: ' + (e.message || e);
                errorMsg.style.display = '';
            }
        }

        function renderStreams() {
            const grid = document.getElementById('stream-grid');
            const count = document.getElementById('stream-count');
            const emptyMsg = document.getElementById('empty-msg');
            const search = document.getElementById('stream-search').value.trim().toLowerCase();
            const errorMsg = document.getElementById('error-msg');
            errorMsg.style.display = 'none';
            let filtered = allStreams;
            if (search) {
                filtered = allStreams.filter(id => id.toLowerCase().includes(search));
            }
            count.textContent = `(${filtered.length})`;
            if (filtered.length === 0) {
                grid.innerHTML = '';
                emptyMsg.style.display = '';
            } else {
                emptyMsg.style.display = 'none';
                grid.innerHTML = '';
                filtered.forEach(id => {
                    const div = document.createElement('div');
                    div.className = 'card';
                    div.style.cursor = 'pointer';
                    div.innerHTML = `
                        <video id="v-${id}" class="video-js vjs-16-9 vjs-default-skin" controls muted autoplay></video>
                        <p>Stream: ${id}</p>
                    `;
                    div.onclick = () => { window.location.href = `/stream/${encodeURIComponent(id)}`; };
                    grid.appendChild(div);
                    if (typeof videojs !== 'undefined') {
                        videojs(`v-${id}`).src({ 
                            type: 'application/x-mpegURL', 
                            src: `/hls/${id}.m3u8` 
                        });
                    }
                });
            }
        }

        document.getElementById('stream-search').addEventListener('input', renderStreams);

        // Kjør oppdatering hvert 5. sekund
        setInterval(update, 5000);
        update();
    </script>
</body>
</html>