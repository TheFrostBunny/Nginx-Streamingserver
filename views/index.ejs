<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title>Live Dashboard</title>
    <!-- Video.js CSS -->
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    <!-- Video.js JS -->
    <script src="/vjs/video.min.js"></script>
    <link href="/dashboard.css" rel="stylesheet" />
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
    <style>
        .chatbox { max-width: 420px; margin: 32px auto 0; background: #181c20; border-radius: 10px; border: 1px solid #333; box-shadow: 0 2px 8px #0004; padding: 16px; }
        .chat-messages { max-height: 250px; overflow-y: auto; background: #111; border-radius: 6px; padding: 8px; margin-bottom: 10px; font-size: 1em; }
        .chat-message { margin-bottom: 6px; }
        .chat-message .user { color: #2e8bff; font-weight: bold; }
        .chat-message .time { color: #aaa; font-size: 0.85em; margin-left: 6px; }
        .chatbox form { display: flex; gap: 6px; }
        .chatbox input, .chatbox button { font-size: 1em; padding: 6px; border-radius: 4px; border: 1px solid #333; }
        .chatbox input { flex: 1; }
        .chatbox button { background: #2e8bff; color: #fff; border: none; cursor: pointer; }
        .chatbox button:hover { background: #1760b0; }
    </style>
</head>
<body>
    <h1>🔴 Aktive strømmer</h1>
    <div id="stream-grid" class="grid"></div>
    <div id="error-msg" class="error" style="display:none"></div>
    <div id="empty-msg" class="empty" style="display:none">Ingen aktive strømmer akkurat nå.</div>

    <div class="chatbox">
        <div class="chat-messages" id="chat-messages"></div>
        <form id="chat-form" autocomplete="off">
            <input type="text" id="chat-username" placeholder="Navn" maxlength="20" required style="width: 80px;">
            <input type="text" id="chat-input" placeholder="Skriv melding..." maxlength="200" required>
            <button type="submit">Send</button>
        </form>
    </div>

    <script>
    let activeStreams = [];
    let players = {};

    async function checkStreamStatus(id) {
        try {
            const res = await fetch(`/api/stream/${id}`);
            const data = await res.json();
            return data.exists;
        } catch {
            return false;
        }
    }

    async function update() {
        try {
            const res = await fetch('/api/streams');
            const streams = await res.json();
            const grid = document.getElementById('stream-grid');
            const errorMsg = document.getElementById('error-msg');
            const emptyMsg = document.getElementById('empty-msg');
            errorMsg.style.display = 'none';
            emptyMsg.style.display = streams.length === 0 ? '' : 'none';
            if (JSON.stringify(streams) !== JSON.stringify(activeStreams)) {
                grid.innerHTML = '';
                // Destroy old players
                Object.values(players).forEach(p => { try { p.dispose(); } catch {} });
                players = {};
                for (const id of streams) {
                    const div = document.createElement('div');
                    div.className = 'card';
                    div.innerHTML = `
                        <div class="stream-title">${id}</div>
                        <div class="status" id="status-${id}">Sjekker status...</div>
                        <video id="v-${id}" class="video-js vjs-16-9 vjs-default-skin" controls muted autoplay playsinline preload="auto"></video>
                    `;
                    grid.appendChild(div);
                    // Init videojs
                    if (typeof videojs !== 'undefined') {
                        players[id] = videojs(`v-${id}`);
                        players[id].src({ type: 'application/x-mpegURL', src: `/hls/${id}.m3u8` });
                    }
                    // Sjekk status
                    checkStreamStatus(id).then(ok => {
                        const el = document.getElementById(`status-${id}`);
                        if (el) el.textContent = ok ? '🟢 Strøm aktiv' : '🔴 Strøm utilgjengelig';
                        if (!ok && players[id]) players[id].pause();
                    });
                }
                activeStreams = streams;
            }
        } catch (e) {
            const errorMsg = document.getElementById('error-msg');
            errorMsg.textContent = 'Feil ved lasting av strømmer: ' + (e.message || e);
            errorMsg.style.display = '';
        }
    }

    setInterval(update, 5000);
    update();

    // --- CHAT ---
    const socket = io();
    const chatMessages = document.getElementById('chat-messages');
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input');
    const chatUsername = document.getElementById('chat-username');

    function escapeHtml(text) {
        return text.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function addMessage(msg) {
        const div = document.createElement('div');
        div.className = 'chat-message';
        div.innerHTML = `<span class="user">${escapeHtml(msg.username)}</span>: ${escapeHtml(msg.message)} <span class="time">${msg.created_at ? new Date(msg.created_at).toLocaleTimeString() : ''}</span>`;
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // Hent siste meldinger
    fetch('/api/chat').then(r => r.json()).then(msgs => { msgs.forEach(addMessage); });

    // Motta nye meldinger
    socket.on('chat message', addMessage);

    chatForm.addEventListener('submit', e => {
        e.preventDefault();
        const username = chatUsername.value.trim() || 'Anon';
        const message = chatInput.value.trim();
        if (!message) return;
        socket.emit('chat message', { username, message });
        chatInput.value = '';
    });
    </script>
</body>
</html>
