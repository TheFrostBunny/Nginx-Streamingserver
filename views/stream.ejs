<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8">
    <title><%= streamId %> | Stream</title>
    <link href="/vjs/video-js.min.css" rel="stylesheet" />
    <script src="/vjs/video.min.js"></script>
    <link href="/dashboard.css" rel="stylesheet" />
    <style>
        body {
            background: #0b0e11;
            color: #f3f3f3;
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            min-height: 100vh;
        }
        header {
            background: #181c20;
            padding: 22px 8vw 12px 8vw;
            position: sticky;
            top: 0;
            z-index: 10;
            box-shadow: 0 2px 8px #0003;
        }
        .back-link {
            color: #7fffa7;
            text-decoration: none;
            font-size: 1.1em;
            margin-bottom: 1.5em;
            display: inline-block;
        }
        .back-link:hover {
            text-decoration: underline;
        }
                .stream-flex {
                    display: flex;
                    gap: 0;
                    align-items: stretch;
                    margin-top: 18px;
                    width: 100vw;
                    max-width: 100vw;
                    min-height: 80vh;
                    background: #15181d;
                    border-radius: 18px;
                    box-shadow: 0 6px 32px #0008;
                    border: 2.5px solid #2e8bff55;
                    overflow: hidden;
                }
                .stream-video {
                    flex: 2 1 0;
                    min-width: 0;
                    max-width: none;
                    display: flex;
                    flex-direction: column;
                    justify-content: stretch;
                    border-right: 2px solid #232a34;
                    background: #181c20;
                }
                .video-js {
                    width: 100%;
                    height: 100vh;
                    min-height: 400px;
                    background: #222;
                    border-radius: 0;
                    box-shadow: 0 2px 16px #0006;
                    border-bottom: 2px solid #232a34;
                }
                .stream-chat {
                    flex: 1 1 420px;
                    min-width: 340px;
                    max-width: 600px;
                    background: #232a34;
                    display: flex;
                    flex-direction: column;
                    justify-content: stretch;
                    box-shadow: -2px 0 12px #0002;
                }
                .chatbox {
                    background: none;
                    border-radius: 0;
                    border: none;
                    box-shadow: none;
                    padding: 24px 12px 12px 12px;
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                }
                .chat-messages {
                    max-height: none;
                    min-height: 0;
                    flex: 1;
                    overflow-y: auto;
                    background: #181c20;
                    border-radius: 8px;
                    border: 1.5px solid #2e8bff33;
                    padding: 10px 10px 8px 10px;
                    margin-bottom: 10px;
                    font-size: 1em;
                    box-shadow: 0 1px 8px #0002;
                }
                .chat-message { margin-bottom: 6px; }
                .chat-message .user { color: #2e8bff; font-weight: bold; }
                .chat-message .time { color: #aaa; font-size: 0.85em; margin-left: 6px; }
                .chatbox form { display: flex; gap: 6px; }
                .chatbox input, .chatbox button { font-size: 1em; padding: 6px; border-radius: 4px; border: 1px solid #333; }
                .chatbox input { flex: 1; }
                .chatbox button { background: #2e8bff; color: #fff; border: none; cursor: pointer; }
                .chatbox button:hover { background: #1760b0; }
                @media (max-width: 1100px) {
                    .stream-flex { flex-direction: column; gap: 0; }
                    .stream-chat { max-width: 100vw; min-width: 0; margin-top: 24px; }
                    .video-js { height: 320px; min-height: 180px; border-radius: 12px; }
                }
            
        
        .video-js {
            width: 100%;
            height: 600px;
            background: #222;
            border-radius: 12px;
        }
        .stream-chat {
            flex: 1 1 340px;
            min-width: 280px;
            max-width: 400px;
        }
        .chatbox {
            background: #232a34;
            border-radius: 10px;
            border: 1px solid #333;
            box-shadow: 0 2px 8px #0004;
            padding: 16px;
        }
        .chat-messages {
            max-height: 400px;
            min-height: 120px;
            overflow-y: auto;
            background: #181c20;
            border-radius: 6px;
            padding: 8px;
            margin-bottom: 10px;
            font-size: 1em;
        }
        .chat-message { margin-bottom: 6px; }
        .chat-message .user { color: #2e8bff; font-weight: bold; }
        .chat-message .time { color: #aaa; font-size: 0.85em; margin-left: 6px; }
        .chatbox form { display: flex; gap: 6px; }
        .chatbox input, .chatbox button { font-size: 1em; padding: 6px; border-radius: 4px; border: 1px solid #333; }
        .chatbox input { flex: 1; }
        .chatbox button { background: #2e8bff; color: #fff; border: none; cursor: pointer; }
        .chatbox button:hover { background: #1760b0; }
        @media (max-width: 1100px) {
            .stream-flex { flex-direction: column; gap: 0; }
            .stream-chat { max-width: 100vw; min-width: 0; margin-top: 24px; }
            .video-js { height: 320px; }
        }
        #stream-status {
            margin: 1em 0 0.5em 0;
            color: #aaa;
        }
        @media (max-width: 900px) {
            main { padding: 10px 2vw; }
            .video-js { height: 220px; }
        }
    </style>
</head>
<body>
    <header>
        <a href="/" class="back-link">← Tilbake til oversikt</a>
    </header>
    <main>
        <div class="stream-title">Stream: <%= streamId %></div>
        <div class="stream-flex">
            <div class="stream-video">
                <video id="vjs-player" class="video-js vjs-16-9 vjs-default-skin" controls autoplay></video>
                <div id="stream-status"></div>
            </div>
            <div class="stream-chat">
                <div class="chatbox">
                    <div class="chat-messages" id="chat-messages"></div>
                    <form id="chat-form" autocomplete="off">
                        <input type="text" id="chat-username" placeholder="Navn" maxlength="20" required style="width: 80px;">
                        <input type="text" id="chat-input" placeholder="Skriv melding..." maxlength="200" required>
                        <button type="submit">Send</button>
                    </form>
                </div>
            </div>
        </div>
    </main>
        <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
    <script>
        const player = videojs('vjs-player');
        player.src({ type: 'application/x-mpegURL', src: '/hls/<%= streamId %>.m3u8' });
        async function checkStatus() {
            try {
                const res = await fetch('/api/stream/<%= streamId %>');
                const data = await res.json();
                document.getElementById('stream-status').textContent = data.exists ? '🟢 Strøm aktiv' : '🔴 Strøm utilgjengelig';
                if (!data.exists) player.pause();
            } catch {
                document.getElementById('stream-status').textContent = 'Kunne ikke sjekke status.';
            }
        }
        checkStatus();
        setInterval(checkStatus, 5000);
        // --- CHAT ---
        const socket = io();
        const chatMessages = document.getElementById('chat-messages');
        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const chatUsername = document.getElementById('chat-username');

        function escapeHtml(text) {
            return text.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        }

        function addMessage(msg) {
            const div = document.createElement('div');
            div.className = 'chat-message';
            div.innerHTML = `<span class="user">${escapeHtml(msg.username)}</span>: ${escapeHtml(msg.message)} <span class="time">${msg.created_at ? new Date(msg.created_at).toLocaleTimeString() : ''}</span>`;
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Hent siste meldinger (kanalspesifikt)
        fetch('/api/chat?stream=<%= encodeURIComponent(streamId) %>').then(r => r.json()).then(msgs => { msgs.forEach(addMessage); });

        // Motta nye meldinger
        socket.on('chat message', function(msg) {
            if(msg.stream === '<%= streamId %>') addMessage(msg);
        });

        chatForm.addEventListener('submit', e => {
            e.preventDefault();
            const username = chatUsername.value.trim() || 'Anon';
            const message = chatInput.value.trim();
            if (!message) return;
            socket.emit('chat message', { username, message, stream: '<%= streamId %>' });
            chatInput.value = '';
        });
    </script>
</body>
</html>
